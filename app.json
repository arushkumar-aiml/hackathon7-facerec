{
  "expo": {
    "name": "Hackathon7 FaceRec",
    "slug": "hackathon7-facerec",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0F1E"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0F1E"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_NETWORK_STATE",
        "INTERNET"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Camera required for facial recognition attendance"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(BUNDLER_ID) to access your camera for facial recognition."
        }
      ]
    ]
  }
}
